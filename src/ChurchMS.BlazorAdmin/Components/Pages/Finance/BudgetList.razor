@page "/budgets"
@attribute [Authorize(Roles = "SuperAdmin,CentralAdmin,ChurchAdmin,Treasurer,DepartmentTreasurer")]
@inject FinanceService FinanceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Budgets — ChurchMS</PageTitle>

<div class="cms-page-header">
    <div class="cms-page-header-left">
        <div class="cms-page-icon" style="background:rgba(1,87,155,0.1);">
            <MudIcon Icon="@Icons.Material.Outlined.BarChart" Color="Color.Info" />
        </div>
        <div class="cms-page-title">
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">Budgets</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Annual budgets and expense tracking
            </MudText>
        </div>
    </div>
</div>

<MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;">
    <MudTable ServerData="@ServerLoad" Dense="false" Hover="true" @ref="_table"
              RowsPerPage="20" Loading="@_loading" LoadingProgressColor="Color.Info"
              Elevation="0">
        <HeaderContent>
            <MudTh Style="font-weight:600;">Name</MudTh>
            <MudTh Style="font-weight:600;">Year</MudTh>
            <MudTh Style="font-weight:600;">Total Amount</MudTh>
            <MudTh Style="font-weight:600;">Period</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Year">
                <MudText Typo="Typo.body2">@context.Year</MudText>
            </MudTd>
            <MudTd DataLabel="Total Amount">
                <MudText Typo="Typo.body2" Style="font-weight:700;">
                    @context.TotalAmount.ToString("N2") @context.Currency
                </MudText>
            </MudTd>
            <MudTd DataLabel="Period">
                <MudText Typo="Typo.body2">
                    @context.StartDate.ToString("d") – @context.EndDate.ToString("d")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small"
                         Color="@BudgetStatusColor(context.Status)"
                         Variant="Variant.Filled" Label="true"
                         Style="border-radius:6px;">
                    @context.Status
                </MudChip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-8 gap-2">
                <MudIcon Icon="@Icons.Material.Outlined.BarChart"
                         Style="font-size:3rem;color:rgba(0,0,0,0.2);" />
                <MudText Color="Color.Secondary">No budgets found.</MudText>
            </div>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<BudgetListDto> _table = null!;
    private bool _loading;

    private async Task<TableData<BudgetListDto>> ServerLoad(TableState state, CancellationToken ct)
    {
        _loading = true;
        try
        {
            var result = await FinanceService.GetBudgetsAsync(
                state.Page + 1, state.PageSize);
            return new TableData<BudgetListDto>
            {
                Items = result?.Items ?? [],
                TotalItems = result?.TotalCount ?? 0
            };
        }
        finally { _loading = false; }
    }

    private static Color BudgetStatusColor(string status) => status switch
    {
        "Draft"  => Color.Default,
        "Active" => Color.Success,
        "Closed" => Color.Dark,
        _ => Color.Default
    };
}
