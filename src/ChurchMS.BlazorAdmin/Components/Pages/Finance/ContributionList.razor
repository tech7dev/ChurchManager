@page "/contributions"
@attribute [Authorize]
@inject FinanceService FinanceService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Contributions — ChurchMS</PageTitle>

<div class="cms-page-header">
    <div class="cms-page-header-left">
        <div class="cms-page-icon" style="background:rgba(46,125,50,0.1);">
            <MudIcon Icon="@Icons.Material.Outlined.Payments" Color="Color.Success" />
        </div>
        <div class="cms-page-title">
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">Contributions</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Track tithes, offerings, and donations
            </MudText>
        </div>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Success"
               StartIcon="@Icons.Material.Outlined.Add"
               Href="/contributions/new"
               Style="border-radius:10px;">Record Contribution</MudButton>
</div>

<MudPaper Elevation="1" Style="border-radius:12px;overflow:hidden;">
    <MudTable ServerData="@ServerLoad" Dense="false" Hover="true" @ref="_table"
              RowsPerPage="20" Loading="@_loading" LoadingProgressColor="Color.Success"
              Elevation="0"
              OnRowClick="@((TableRowClickEventArgs<ContributionListDto> row) => Navigation.NavigateTo($"/contributions/{row.Item.Id}"))">
        <HeaderContent>
            <MudTh Style="font-weight:600;">Reference</MudTh>
            <MudTh Style="font-weight:600;">Date</MudTh>
            <MudTh Style="font-weight:600;">Member / Donor</MudTh>
            <MudTh Style="font-weight:600;">Fund</MudTh>
            <MudTh Style="font-weight:600;">Campaign</MudTh>
            <MudTh Style="font-weight:600;">Type</MudTh>
            <MudTh Style="font-weight:600;">Amount</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Ref">
                <MudText Typo="Typo.caption"
                         Style="font-family:monospace;color:rgba(0,0,0,0.55);">
                    @context.ReferenceNumber
                </MudText>
            </MudTd>
            <MudTd DataLabel="Date">
                <MudText Typo="Typo.body2">@context.ContributionDate.ToString("d")</MudText>
            </MudTd>
            <MudTd DataLabel="Member">
                <MudText Typo="Typo.body2" Style="font-weight:500;">
                    @(context.MemberName ?? context.AnonymousDonorName ?? "Anonymous")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Fund">
                <MudText Typo="Typo.body2">@context.FundName</MudText>
            </MudTd>
            <MudTd DataLabel="Campaign">
                <MudText Typo="Typo.body2">@(context.CampaignName ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="Type">
                <MudText Typo="Typo.body2">@context.Type</MudText>
            </MudTd>
            <MudTd DataLabel="Amount">
                <MudText Style="font-weight:700;color:#2e7d32;">
                    @context.Amount.ToString("N2") @context.Currency
                </MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small"
                         Color="@ContributionStatusColor(context.Status)"
                         Variant="Variant.Filled" Label="true"
                         Style="border-radius:6px;">
                    @context.Status
                </MudChip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-8 gap-2">
                <MudIcon Icon="@Icons.Material.Outlined.Payments"
                         Style="font-size:3rem;color:rgba(0,0,0,0.2);" />
                <MudText Color="Color.Secondary">No contributions found.</MudText>
            </div>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<ContributionListDto> _table = null!;
    private bool _loading;

    private async Task<TableData<ContributionListDto>> ServerLoad(TableState state, CancellationToken ct)
    {
        _loading = true;
        try
        {
            var result = await FinanceService.GetContributionsAsync(
                state.Page + 1, state.PageSize);
            return new TableData<ContributionListDto>
            {
                Items = result?.Items ?? [],
                TotalItems = result?.TotalCount ?? 0
            };
        }
        finally { _loading = false; }
    }

    private static Color ContributionStatusColor(ContributionStatus status) => status switch
    {
        ContributionStatus.Confirmed => Color.Success,
        ContributionStatus.Pending   => Color.Warning,
        ContributionStatus.Cancelled => Color.Error,
        _ => Color.Default
    };
}
