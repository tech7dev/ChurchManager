@page "/reports/financial"
@attribute [Authorize(Roles = "SuperAdmin,CentralAdmin,ChurchAdmin,Treasurer")]
@inject ReportService ReportService
@inject ISnackbar Snackbar

<PageTitle>Financial Report — ChurchMS</PageTitle>

<div class="cms-page-header">
    <div class="cms-page-header-left">
        <div class="cms-page-icon" style="background:rgba(46,125,50,0.1);">
            <MudIcon Icon="@Icons.Material.Outlined.BarChart" Color="Color.Success" />
        </div>
        <div class="cms-page-title">
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">Financial Report</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Contributions, expenses, and net income over a date range
            </MudText>
        </div>
    </div>
</div>

<MudPaper Class="mb-5 pa-4" Elevation="1" Style="border-radius:12px;">
    <MudGrid Spacing="3">
        <MudItem xs="12" sm="4">
            <MudDatePicker Label="From" @bind-Date="_from"
                           DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudDatePicker Label="To" @bind-Date="_to"
                           DateFormat="yyyy-MM-dd" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Search"
                       OnClick="@Load" Disabled="@_loading" FullWidth="true"
                       Style="border-radius:10px;height:56px;">
                Generate Report
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4"
                       Style="border-radius:2px;" />
}

@if (_data is not null)
{
    <MudGrid Spacing="3" Class="mb-5">
        <MudItem xs="12" sm="4">
            <StatCard Title="Total Contributions" Value="@_data.TotalContributions.ToString("N2")"
                      SubTitle="@_data.Currency"
                      Icon="@Icons.Material.Outlined.Payments" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <StatCard Title="Total Expenses" Value="@_data.TotalExpenses.ToString("N2")"
                      SubTitle="@_data.Currency"
                      Icon="@Icons.Material.Outlined.Receipt" Color="Color.Error" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <StatCard Title="Net Income" Value="@_data.NetIncome.ToString("N2")"
                      SubTitle="@_data.Currency"
                      Icon="@Icons.Material.Outlined.AccountBalance"
                      Color="@(_data.NetIncome >= 0 ? Color.Success : Color.Error)" />
        </MudItem>
    </MudGrid>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudCard Elevation="1" Style="border-radius:12px;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Outlined.Payments" Color="Color.Success" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                            Contributions by Fund
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent Class="pa-0">
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th style="font-weight:600;">Fund</th>
                                <th style="font-weight:600;">Count</th>
                                <th style="font-weight:600;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fund in _data.ByFund)
                            {
                                <tr>
                                    <td>@fund.FundName</td>
                                    <td>@fund.Count</td>
                                    <td style="font-weight:700;color:#2e7d32;">
                                        @fund.Total.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="1" Style="border-radius:12px;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Outlined.Receipt" Color="Color.Error" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                            Expenses by Category
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent Class="pa-0">
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th style="font-weight:600;">Category</th>
                                <th style="font-weight:600;">Count</th>
                                <th style="font-weight:600;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in _data.ExpensesByCategory)
                            {
                                <tr>
                                    <td>@cat.Category</td>
                                    <td>@cat.Count</td>
                                    <td style="font-weight:700;color:#c62828;">
                                        @cat.Total.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12">
            <MudCard Elevation="1" Style="border-radius:12px;">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@Icons.Material.Outlined.Timeline" Color="Color.Primary" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
                            Monthly Trend
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudDivider />
                <MudCardContent Class="pa-0">
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th style="font-weight:600;">Month</th>
                                <th style="font-weight:600;">Contributions</th>
                                <th style="font-weight:600;">Expenses</th>
                                <th style="font-weight:600;">Net</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in _data.MonthlyContributionTrend)
                            {
                                var net = m.Contributions - m.Expenses;
                                <tr>
                                    <td>@m.MonthLabel</td>
                                    <td style="color:#2e7d32;">@m.Contributions.ToString("N2")</td>
                                    <td style="color:#c62828;">@m.Expenses.ToString("N2")</td>
                                    <td style="font-weight:700;color:@(net >= 0 ? "#2e7d32" : "#c62828");">
                                        @net.ToString("N2")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private DateTime? _from = DateTime.UtcNow.AddMonths(-6);
    private DateTime? _to = DateTime.UtcNow;
    private FinancialSummaryDto? _data;
    private bool _loading;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        if (_from is null || _to is null) return;
        _loading = true;
        try
        {
            _data = await ReportService.GetFinancialSummaryAsync(_from.Value, _to.Value);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading report: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }
}
