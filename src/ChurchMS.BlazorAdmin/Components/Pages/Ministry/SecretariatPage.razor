@page "/secretariat"
@attribute [Authorize(Roles = "SuperAdmin,CentralAdmin,ChurchAdmin,Secretary")]
@inject MinistryService MinistryService
@inject ISnackbar Snackbar

<PageTitle>Secretariat — ChurchMS</PageTitle>

<div class="cms-page-header">
    <div class="cms-page-header-left">
        <div class="cms-page-icon" style="background:rgba(84,110,122,0.1);">
            <MudIcon Icon="@Icons.Material.Outlined.Description" Color="Color.Secondary" />
        </div>
        <div class="cms-page-title">
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2;">Secretariat</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Documents, certificates, baptism and marriage records
            </MudText>
        </div>
    </div>
</div>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4"
         ActivePanelIndexChanged="@OnTabChanged">
    <MudTabPanel Text="Documents" Icon="@Icons.Material.Outlined.Folder">
        <MudPaper Elevation="0" Style="border-radius:0 0 12px 12px;overflow:hidden;">
            <MudTable ServerData="@DocumentsServerLoad" Dense="false" Hover="true" @ref="_documentsTable"
                      RowsPerPage="20" Loading="@_documentsLoading" LoadingProgressColor="Color.Secondary"
                      Elevation="0">
                <HeaderContent>
                    <MudTh Style="font-weight:600;">Title</MudTh>
                    <MudTh Style="font-weight:600;">File Name</MudTh>
                    <MudTh Style="font-weight:600;">Type</MudTh>
                    <MudTh Style="font-weight:600;">Size</MudTh>
                    <MudTh Style="font-weight:600;">Date</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Title">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Title</MudText>
                    </MudTd>
                    <MudTd DataLabel="File Name">
                        <MudText Typo="Typo.body2">@context.FileName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Size="Size.Small"
                                 Variant="Variant.Filled" Label="true"
                                 Style="border-radius:6px;">
                            @context.Type
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Size">
                        <MudText Typo="Typo.body2">@FormatFileSize(context.FileSize)</MudText>
                    </MudTd>
                    <MudTd DataLabel="Date">
                        <MudText Typo="Typo.body2">@context.CreatedAt.ToString("g")</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="d-flex flex-column align-center pa-8 gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.Folder"
                                 Style="font-size:3rem;color:rgba(0,0,0,0.2);" />
                        <MudText Color="Color.Secondary">No documents found.</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudTabPanel>

    <MudTabPanel Text="Certificates" Icon="@Icons.Material.Outlined.CardMembership">
        <MudPaper Elevation="0" Style="border-radius:0 0 12px 12px;overflow:hidden;">
            <MudTable ServerData="@CertificatesServerLoad" Dense="false" Hover="true" @ref="_certificatesTable"
                      RowsPerPage="20" Loading="@_certificatesLoading" LoadingProgressColor="Color.Secondary"
                      Elevation="0">
                <HeaderContent>
                    <MudTh Style="font-weight:600;">Certificate #</MudTh>
                    <MudTh Style="font-weight:600;">Type</MudTh>
                    <MudTh Style="font-weight:600;">Member</MudTh>
                    <MudTh Style="font-weight:600;">Issued Date</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Certificate #">
                        <MudText Typo="Typo.body2" Style="font-weight:600;font-family:monospace;">
                            @context.CertificateNumber
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Size="Size.Small"
                                 Variant="Variant.Filled" Label="true"
                                 Style="border-radius:6px;">
                            @context.Type
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Member">
                        <MudText Typo="Typo.body2">@(context.MemberName ?? "—")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Issued Date">
                        <MudText Typo="Typo.body2">@context.IssuedDate.ToString("d")</MudText>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <div class="d-flex flex-column align-center pa-8 gap-2">
                        <MudIcon Icon="@Icons.Material.Outlined.CardMembership"
                                 Style="font-size:3rem;color:rgba(0,0,0,0.2);" />
                        <MudText Color="Color.Secondary">No certificates found.</MudText>
                    </div>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudPaper>
    </MudTabPanel>
</MudTabs>

@code {
    private MudTable<DocumentListDto> _documentsTable = null!;
    private MudTable<CertificateListDto> _certificatesTable = null!;
    private bool _documentsLoading;
    private bool _certificatesLoading;

    private async Task<TableData<DocumentListDto>> DocumentsServerLoad(TableState state, CancellationToken ct)
    {
        _documentsLoading = true;
        try
        {
            var result = await MinistryService.GetDocumentsAsync(state.Page + 1, state.PageSize);
            return new TableData<DocumentListDto>
            {
                Items = result?.Items ?? [],
                TotalItems = result?.TotalCount ?? 0
            };
        }
        finally { _documentsLoading = false; }
    }

    private async Task<TableData<CertificateListDto>> CertificatesServerLoad(TableState state, CancellationToken ct)
    {
        _certificatesLoading = true;
        try
        {
            var result = await MinistryService.GetCertificatesAsync(state.Page + 1, state.PageSize);
            return new TableData<CertificateListDto>
            {
                Items = result?.Items ?? [],
                TotalItems = result?.TotalCount ?? 0
            };
        }
        finally { _certificatesLoading = false; }
    }

    private void OnTabChanged(int index)
    {
        if (index == 0)
            _documentsTable?.ReloadServerData();
        else if (index == 1)
            _certificatesTable?.ReloadServerData();
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1_048_576)
            return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)
            return $"{bytes / 1_024.0:F1} KB";
        return $"{bytes} B";
    }
}
